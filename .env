# Режим отладки
# В production обязательно установите DEBUG=False
DEBUG=True

# Хост и порт
HOST=0.0.0.0
PORT=15191

# Пути к данным
UPLOAD_DIR=/opt/dix/aspic/data/files
PREVIEW_DIR=/opt/dix/aspic/data/preview
DB_PATH=/opt/dix/aspic/data/aspic.db

# Время жизни временных файлов (1 час)
PREVIEW_TTL_SECONDS=3600

# Ограничения (104857600 = 100 MB) - должен быть меньше, чем client_max_body_size в nginx
MAX_FILE_SIZE=104857600
TOKEN_LENGTH=12

# ВСЕ поддерживаемые MIME-типы
ALLOWED_MIMES=image/jpeg,image/jpg,image/png,image/gif,image/webp,image/svg+xml,image/bmp,image/tiff,image/x-icon,application/pdf,application/x-pdf,video/mp4,video/webm,video/ogg,video/quicktime,video/x-msvideo,video/x-matroska,audio/mpeg,audio/ogg,audio/wav,audio/aac,audio/flac,audio/mp4,text/plain,text/html,text/css,text/javascript,text/markdown,text/csv,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/zip,application/x-zip-compressed,application/x-rar-compressed,application/x-7z-compressed,application/x-tar,application/gzip

# Rate limiting - ограничение количества операций в минуту (защита от спама)
RATE_LIMIT_UPLOAD=25/minute
RATE_LIMIT_COMMENT=3/minute
RATE_LIMIT_DELETE=3/minute

# Капча
CAPTCHA_TTL_SECONDS=300

# ============================================
# НАСТРОЙКИ ВЕБХУКОВ (безопасность)
# ============================================
# Вебхуки позволяют внешним сервисам контролировать доступ к файлам.
# При каждой попытке открыть файл ASPIC вызывает указанный URL,
# передавая все параметры запроса, и ожидает ответ {"allowed": "1"} или {"allowed": "0"}.
# Ниже приведены настройки безопасности для защиты от злоупотреблений.

# ----------------------------------------------------------------------
# ТАЙМАУТЫ - защита от медленных или зависших вебхуков
# ----------------------------------------------------------------------
# WEBHOOK_TIMEOUT - общий таймаут на весь запрос к вебхуку (сек)
# Если вебхук не ответит за это время, доступ будет запрещён.
# Слишком большое значение может привести к исчерпанию соединений.
# Слишком маленькое - к ложным срабатываниям на медленных серверах.
WEBHOOK_TIMEOUT=5

# WEBHOOK_CONNECT_TIMEOUT - таймаут на установку соединения (сек)
# Защита от недоступных серверов и проблем с сетью.
WEBHOOK_CONNECT_TIMEOUT=3

# WEBHOOK_READ_TIMEOUT - таймаут на чтение ответа (сек)
# Защита от медленной передачи данных.
WEBHOOK_READ_TIMEOUT=5

# ----------------------------------------------------------------------
# RATE LIMITING - защита от DDoS и чрезмерной нагрузки
# ----------------------------------------------------------------------
# WEBHOOK_RATE_LIMIT_PER_URL - сколько раз в минуту можно вызывать ОДИН конкретный вебхук
# Защищает внешний сервис от чрезмерной нагрузки с нашей стороны.
# Например, если файл популярен, мы не будем дёргать вебхук слишком часто.
WEBHOOK_RATE_LIMIT_PER_URL=10

# WEBHOOK_RATE_LIMIT_PER_IP - сколько вызовов вебхуков в минуту может сделать ОДИН IP-адрес
# Защищает нас от ситуации, когда злоумышленник пытается вызвать много разных вебхуков
# с одного IP (например, перебором параметров).
WEBHOOK_RATE_LIMIT_PER_IP=30

# WEBHOOK_MAX_CONCURRENT_PER_IP - сколько одновременных запросов к вебхукам может делать один IP
# Защита от попытки исчерпать соединения множеством параллельных запросов.
WEBHOOK_MAX_CONCURRENT_PER_IP=5

# ----------------------------------------------------------------------
# ОГРАНИЧЕНИЯ НА РАЗМЕР ДАННЫХ - защита от переполнения памяти
# ----------------------------------------------------------------------
# WEBHOOK_MAX_RESPONSE_SIZE - максимальный размер ответа от вебхука (в байтах)
# Защита от ситуации, когда вебхук пытается вернуть огромный ответ,
# что может привести к исчерпанию памяти.
# 1048576 байт = 1 МБ - достаточно для JSON с простым ответом.
WEBHOOK_MAX_RESPONSE_SIZE=1048576

# WEBHOOK_MAX_HEADERS_SIZE - максимальный размер заголовков ответа (в байтах)
# Защита от атак через огромные заголовки.
WEBHOOK_MAX_HEADERS_SIZE=8192

# ----------------------------------------------------------------------
# КЭШИРОВАНИЕ - оптимизация производительности
# ----------------------------------------------------------------------
# WEBHOOK_CACHE_TTL - время жизни кэша ответов вебхуков (в секундах)
# Если один и тот же пользователь с одними и теми же параметрами
# запрашивает файл, мы не будем каждый раз дёргать вебхук,
# а используем закэшированный ответ.
# 300 секунд = 5 минут - оптимально для большинства случаев.
WEBHOOK_CACHE_TTL=300

# ============================================
# ПОЧЕМУ ЭТО ВАЖНО:
# ============================================
# Без этих настроек злоумышленник может:
# 1. Вызвать вебхук на свой медленный сервер и исчерпать наши соединения
# 2. Вызвать один и тот же вебхук тысячи раз в минуту (DDoS внешнего сервиса)
# 3. Передать в параметрах гигантские значения и вызвать переполнение
# 4. Использовать наш сервер для атак на внешние сервисы (как прокси)
#
# Рекомендации по настройке:
# - В режиме DEBUG можно увеличить лимиты для тестирования
# - В production рекомендуется оставить значения по умолчанию
# - При работе с особо важными файлами можно уменьшить лимиты
# - При проблемах с доступом - проверьте таймауты и rate limits